{
  "name": "carrousel-core-monorepo",
  "version": "0.2.0",
  "private": true,
  "description": "Editor de carruseles para redes sociales con motor de layout profesional",
  "scripts": {
    "dev": "pnpm --filter @carrousel/web dev",
    "dev:bff": "pnpm --filter @carrousel/bff dev",
    "build": "pnpm --filter @carrousel/web build",
    "build:bff": "pnpm --filter @carrousel/bff build",
    "preview": "pnpm --filter @carrousel/web preview",
    "typecheck": "pnpm -r typecheck"
  },
  "packageManager": "pnpm@9.12.2",
  "engines": {
    "node": ">=20"
  }
}
